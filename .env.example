# Database configuration
POSTGRES_USER=codebot
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=codebot_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432

# App configuration
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=generate_a_secure_random_key_here

# Security - Token Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate_a_fernet_key_here

# Database URL (used by SQLAlchemy)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://codebot:your_secure_password_here@db:5432/codebot_dev
